{
	"manifest_version": 3,
	"name": "Instagram Post Viewer",
	"version": "1.0.0",
	"description": "Adds a button to Instagram posts to preview image and caption.",
	"permissions": ["activeTab"],
	"host_permissions": ["https://www.instagram.com/*", "https://scoldable-liza-semipervious.ngrok-free.dev/*", "https://api.cloudinary.com/*", "https://res.cloudinary.com/*"],
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"content_scripts": [
		{
			"matches": ["https://www.instagram.com/*"],
			"js": ["content.js"],
			"run_at": "document_idle"
		}
	],
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	}
}
